{{!< default}}

{{#post}}
<main>
    <div class="gm-page-wrapper">

        <h1 class="gm-page-title">{{title}}</h1>

        {{#if feature_image}}
            <img
                class="gm-article-feature-image"
                src="{{img_url feature_image size="xl"}}"
                alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
            >
        {{/if}}

        <div class="gm-article-content">
            {{content}}
        </div>

    </div>
</main>
{{/post}}

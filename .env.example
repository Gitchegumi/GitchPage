# Next.js Configuration
NEXT_PUBLIC_SITE_URL=https://www.gitchegumi.com

# Listmonk Configuration
LISTMONK_URL=https://monk.gitchegumi.com
# API user created in Listmonk Admin → Users
LISTMONK_API_USER=your_listmonk_api_username_here
LISTMONK_API_KEY=your_listmonk_api_key_here
LISTMONK_BLOG_LIST_NAME=Blog Subscribers
LISTMONK_BLOG_LIST_ID=3
# ID of the "New Blog Post" template campaign to clone for each new post
LISTMONK_CAMPAIGN_TEMPLATE_ID=2

# Webhook secret — set this to a random string and add it as a GitHub Actions secret
WEBHOOK_SECRET=
